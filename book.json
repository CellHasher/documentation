{
  "title": "Cellhasher Documentation",
  "description": "Official documentation for Cellhasher",
  "language": "en",
  "structure": {
    "readme": "README.md",
    "summary": "SUMMARY.md"
  },
  "ignore": [
    "node_modules",
    ".vscode",
    ".github",
    "_book",
    "LOCAL-DEVELOPMENT.md",
    "scripts"
  ],
  "plugins": ["add-js", "chollapse", "-sharing", "-fontsettings", "-livereload"],
  "pluginsConfig": {
    "add-js": {
      "js": [
        "./docs/assets/js/theme.js",
        "./docs/assets/js/analytics-config.js",
        "./docs/assets/js/consent.js",
        "./docs/assets/js/os-detect.js",
        "./docs/assets/js/edit-link.js",
        "./docs/assets/js/copy-code.js",
        "./docs/assets/js/right-toc.js"
      ]
    },
    "chollapse": {}
  }
}
