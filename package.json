{
  "name": "cellhasher-documentation",
  "version": "1.0.0",
  "description": "Official documentation for Cellhasher",
  "scripts": {
    "build": "honkit build . _book",
    "serve": "honkit serve .",
    "test": "npm run lint && npm run links",
    "lint": "markdownlint \"**/*.md\" --ignore node_modules --ignore _book",
    "links": "find . -name '*.md' ! -path './node_modules/*' ! -path './_book/*' -print0 | xargs -0 -I{} markdown-link-check -c .mlc.json --quiet {}"
  },
  "devDependencies": {
    "honkit": "^5.7.2",
    "markdownlint-cli": "^0.43.0",
    "markdown-link-check": "^3.13.6"
  }
}
